{
    "name": "axleus/axleus-message",
    "description": "Webware CommandBus driven message service for axleus applications",
    "license": "BSD-3-Clause",
    "keywords": [
        "axleus",
        "mezzio",
        "message abstraction"
    ],
    "homepage": "https://github.com/orgs/axleus/discussions",
    "support": {
        "issues": "https://github.com/axleus/axleus-message/issues",
        "chat": "https://discord.gg/9TxQ74EPsG"
    },
    "authors": [
        {
            "name": "Joey Smith",
            "email": "jsmith@webinertia.net"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../../webware/*"
        }
    ],
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "mezzio/mezzio-session-ext": "^1.21.0",
        "webware/command-bus": "^0.5.0"
    },
    "require-dev": {
        "axleus/axleus-mailer": "dev-master",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^13.0.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "roave/security-advisories": "dev-master",
        "webware/coding-standard": "^0.1.0",
        "webware/commandbus-event": "0.1.x-dev",
        "webware/traccio": "^0.1.0"
    },
    "extra": {
        "laminas": {
            "config-provider": "Axleus\\Message\\ConfigProvider"
        }
    },
    "autoload": {
        "psr-4": {
            "Axleus\\Message\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AxleusTest\\Message\\": "test/"
        }
    },
    "scripts": {
        "check": [
            "@cs-check",
            "@sa",
            "@test"
        ],
        "cs-check": "vendor/bin/php-cs-fixer check",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "test": "phpunit --colors=always",
        "test-coverage": "phpunit --colors=always --coverage-clover clover.xml",
        "sa": "vendor/bin/phpstan analyse --memory-limit=256M",
        "sa-gen-baseline": "vendor/bin/phpstan analyse --memory-limit=256M --generate-baseline",
        "sa-verbose": "vendor/bin/phpstan analyse --memory-limit=256M -vv"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2.99"
        },
        "allow-plugins": {
            "laminas/laminas-component-installer": true,
            "composer/package-versions-deprecated": true
        }
    }
}
